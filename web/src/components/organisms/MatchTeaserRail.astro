---
---

<section class="match-rail" aria-labelledby="match-rail-title" data-match-highlights hidden>
  <div class="match-rail__heading"><span></span><h2 id="match-rail-title">Partidas em destaque</h2><span></span></div>
  <div class="match-rail__list" data-match-highlights-list></div>
</section>

<script>
  import { matchStatusLabel } from "../../scripts/presentation";
  import { apiBaseUrl } from "../../scripts/session";

  type Highlight = {
    matchId: string;
    teamHome: string;
    teamAway: string;
    start: string;
    status: string;
    totalStakeCents: number;
  };

  const crestThemes = [
    ["#3c8cff", "#d9f3ff", "shield"],
    ["#ff5d19", "#ffd0b9", "diamond"],
    ["#c7ff37", "#efffc0", "round"],
    ["#32d7ff", "#baf4ff", "shield"],
    ["#b770ff", "#ead7ff", "diamond"],
    ["#ff3a4d", "#ffcad0", "round"],
  ] as const;

  const rail = document.querySelector<HTMLElement>("[data-match-highlights]");
  const list = document.querySelector<HTMLElement>("[data-match-highlights-list]");

  const text = (tag: string, content: string, className?: string) => {
    const element = document.createElement(tag);
    element.textContent = content;
    if (className) element.className = className;
    return element;
  };

  const appearanceFor = (name: string) => {
    const index = Array.from(name).reduce((total, character) => total + character.charCodeAt(0), 0) % crestThemes.length;
    return crestThemes[index];
  };

  const team = (name: string) => {
    const [primary, secondary, variant] = appearanceFor(name);
    const wrapper = document.createElement("span");
    wrapper.className = "match-teaser__team";
    const crest = document.createElement("span");
    crest.className = `team-crest team-crest--${variant}`;
    crest.style.setProperty("--crest-primary", primary);
    crest.style.setProperty("--crest-secondary", secondary);
    crest.setAttribute("aria-label", name);
    crest.title = name;
    crest.append(text("span", "", "team-crest__shine"), text("strong", name.trim().charAt(0).toUpperCase()));
    wrapper.append(crest, text("small", name));
    return wrapper;
  };

  const liveStatuses = new Set(["LIVE", "IN_PROGRESS"]);
  const timeLabel = (start: string) => new Intl.DateTimeFormat("pt-BR", { hour: "2-digit", minute: "2-digit" }).format(new Date(start));
  const money = (cents: number) => new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL" }).format(cents / 100);

  const renderHighlight = (highlight: Highlight) => {
    const item = document.createElement("article");
    item.className = "match-teaser";
    item.dataset.matchId = highlight.matchId;
    const header = document.createElement("header");
    const status = text("span", matchStatusLabel(highlight.status));
    if (liveStatuses.has(highlight.status)) status.classList.add("match-teaser__live");
    header.append(status, text("time", timeLabel(highlight.start)));

    const teams = document.createElement("div");
    teams.className = "match-teaser__teams";
    teams.setAttribute("aria-label", `${highlight.teamHome} contra ${highlight.teamAway}`);
    teams.append(team(highlight.teamHome), text("b", "×"), team(highlight.teamAway));

    const stake = document.createElement("div");
    stake.className = "match-teaser__stake";
    stake.append(text("small", "MONTANTE NO BOLÃO"), text("strong", money(highlight.totalStakeCents)));
    item.append(header, teams, stake);
    return item;
  };

  const loadHighlights = async () => {
    if (!rail || !list) return;
    try {
      // TODO(palpites-service): GET /api/palpites/destaques retorna { highlights: Highlight[] }.
      // Cada destaque é público e agregado: nunca inclui placar previsto nem identidade de usuário.
      const response = await fetch(`${apiBaseUrl}/palpites/destaques`);
      if (!response.ok || response.status === 204) return;
      const payload = await response.json() as { highlights?: Highlight[] };
      if (!Array.isArray(payload.highlights) || payload.highlights.length === 0) return;
      list.replaceChildren(...payload.highlights.map(renderHighlight));
      rail.hidden = false;
    } catch {
      // O serviço ainda não existe neste incremento: a ausência de destaques é intencional e silenciosa.
    }
  };

  void loadHighlights();
</script>

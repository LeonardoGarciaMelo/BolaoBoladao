---
interface Props {
  name: "user" | "lock" | "trophy" | "target" | "chart" | "arrow" | "logout" | "ball";
  size?: number;
  title?: string;
}

const { name, size = 20, title } = Astro.props;
const paths = {
  user: '<path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/>',
  lock: '<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
  trophy: '<path d="M8 21h8M12 17v4M7 4h10v6a5 5 0 0 1-10 0V4Z"/><path d="M7 6H4v1a4 4 0 0 0 4 4M17 6h3v1a4 4 0 0 1-4 4"/>',
  target: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><path d="m16 8 5-5M18 3h3v3"/>',
  chart: '<path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  logout: '<path d="M10 17l5-5-5-5M15 12H3M21 19V5a2 2 0 0 0-2-2h-6"/>',
  ball: '<circle cx="12" cy="12" r="9"/><path d="m12 3 3 4-3 3-3-3 3-4ZM3.5 10l5 .5 1.5 4-3.5 3M20.5 10l-5 .5-1.5 4 3.5 3M12 17l-2 3"/>',
}[name];
---

<svg
  class="icon"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={title ? undefined : "true"}
  role={title ? "img" : undefined}
  set:html={paths}
>
  {title && <title>{title}</title>}
</svg>

---
import Layout from "../layouts/Layout.astro";
import UserShell from "../components/templates/UserShell.astro";
---

<Layout title="Partidas | Bolão Boladão">
  <UserShell active="matches" eyebrow="ÁREA DO BOLÃO" title="Partidas">
    <section class="user-toolbar" aria-label="Filtros de partidas">
      <div class="user-filter-group" data-match-filters>
        <button type="button" data-view="OPEN" aria-pressed="true">ABERTAS</button>
        <button type="button" data-view="LIVE" aria-pressed="false">AO VIVO</button>
        <button type="button" data-view="FINISHED" aria-pressed="false">ENCERRADAS</button>
        <button type="button" data-view="CANCELED" aria-pressed="false">CANCELADAS</button>
      </div>
    </section>
    <section class="user-card-grid" data-match-list aria-live="polite"></section>
    <div class="user-list-state" data-match-state>Carregando partidas…</div>
    <button class="user-load-more" type="button" data-match-more hidden>CARREGAR MAIS</button>
  </UserShell>
</Layout>

<dialog class="user-dialog bet-dialog" data-bet-dialog>
  <div class="user-dialog__surface">
    <button class="user-dialog__close" type="button" data-bet-close aria-label="Fechar">×</button>
    <span class="user-dialog__eyebrow">PALPITE INDIVIDUAL</span>
    <h2 data-bet-match>Fazer palpite</h2>

    <form class="bet-form" data-bet-form>
      <p class="bet-form__kickoff" data-bet-kickoff></p>
      <fieldset class="bet-score-fields">
        <legend>PLACAR PREVISTO</legend>
        <label><span data-home-label>Mandante</span><input name="homeGoals" type="number" min="0" max="30" inputmode="numeric" required /></label>
        <b>×</b>
        <label><span data-away-label>Visitante</span><input name="awayGoals" type="number" min="0" max="30" inputmode="numeric" required /></label>
      </fieldset>
      <label class="bet-stake">VALOR DA APOSTA<div><span>R$</span><input name="stake" inputmode="decimal" placeholder="0,00" required /></div></label>
      <p class="bet-balance-copy">Saldo disponível: <strong data-bet-balance>R$ 0,00</strong></p>
      <p class="user-form-message" data-bet-message role="alert"></p>
      <button class="user-primary-action" type="submit">REVISAR PALPITE</button>
    </form>

    <section data-bet-review hidden>
      <dl class="bet-review-list">
        <div><dt>Partida</dt><dd data-review-match></dd></div>
        <div><dt>Seu placar</dt><dd data-review-score></dd></div>
        <div><dt>Valor</dt><dd data-review-stake></dd></div>
        <div><dt>Saldo estimado</dt><dd data-review-balance></dd></div>
      </dl>
      <p class="user-form-message" data-review-message role="alert"></p>
      <div class="user-dialog__actions">
        <button class="user-secondary-action" type="button" data-bet-back>EDITAR</button>
        <button class="user-primary-action" type="button" data-bet-confirm>CONFIRMAR PALPITE</button>
      </div>
    </section>

    <section class="bet-result" data-bet-result hidden aria-live="polite">
      <span class="bet-result__pulse"></span><h3>Processando pagamento…</h3><p>Aguarde enquanto confirmamos seu saldo.</p>
      <div class="user-dialog__actions"><a class="user-secondary-action" href="/palpites">VER MEUS PALPITES</a><button class="user-primary-action" type="button" data-bet-done>FECHAR</button></div>
    </section>
  </div>
</dialog>

<script>
  import { authenticatedFetch, createIdempotencyKey } from "../scripts/session";
  import { formatCents, refreshWallet } from "../scripts/user";

  type Match = { id: string; teamHome: string; teamAway: string; teamHomeScore: number; teamAwayScore: number; start: string; end?: string; status: string; bettingOpen: boolean };
  type Page = { items: Match[]; page: number; size: number; total: number };
  type BetStatus = "PROCESSING" | "CONFIRMED" | "AWAITING_SETTLEMENT" | "PAYMENT_REFUSED" | "CANCELING" | "REFUNDING" | "CANCELED" | "REFUND_FAILED";
  type Bet = { bet_id: string; status: BetStatus };
  let currentView = "OPEN"; let currentPage = 0; let total = 0; let selected: Match | undefined;
  let pending: { home: number; away: number; stakeCents: number; key: string } | undefined;
  const list = document.querySelector<HTMLElement>("[data-match-list]");
  const state = document.querySelector<HTMLElement>("[data-match-state]");
  const more = document.querySelector<HTMLButtonElement>("[data-match-more]");
  const dialog = document.querySelector<HTMLDialogElement>("[data-bet-dialog]");
  const form = document.querySelector<HTMLFormElement>("[data-bet-form]");
  const review = document.querySelector<HTMLElement>("[data-bet-review]");
  const result = document.querySelector<HTMLElement>("[data-bet-result]");
  const dateTime = new Intl.DateTimeFormat("pt-BR", { dateStyle: "medium", timeStyle: "short" });

  const balanceCents = () => Number(document.querySelector<HTMLElement>("[data-user-balance]")?.dataset.balanceCents || 0);
  const parseCents = (value: string) => Math.round(Number(value.replace(/\./g, "").replace(",", ".")) * 100);
  const statusLabel = (status: string) => ({ SCHEDULED: "AGENDADA", IN_PROGRESS: "AO VIVO", FINISHED: "ENCERRADA", CANCELED: "CANCELADA" }[status] || status);

  const renderMatch = (match: Match) => {
    const article = document.createElement("article"); article.className = "user-match-card";
    const meta = document.createElement("div"); meta.className = "user-match-card__meta";
    const badge = document.createElement("span"); badge.dataset.status = match.status.toLowerCase(); badge.textContent = statusLabel(match.status);
    const time = document.createElement("time"); time.dateTime = match.start; time.textContent = dateTime.format(new Date(match.start)); meta.append(badge, time);
    const teams = document.createElement("div"); teams.className = "user-match-card__teams";
    const home = document.createElement("strong"); home.textContent = match.teamHome;
    const score = document.createElement("b"); score.textContent = match.status === "SCHEDULED" ? "×" : `${match.teamHomeScore} × ${match.teamAwayScore}`;
    const away = document.createElement("strong"); away.textContent = match.teamAway; teams.append(home, score, away);
    const footer = document.createElement("footer");
    if (match.bettingOpen) {
      const button = document.createElement("button"); button.type = "button"; button.className = "user-primary-action"; button.textContent = "FAZER PALPITE";
      button.addEventListener("click", () => openBet(match)); footer.append(button);
    } else { const closed = document.createElement("span"); closed.textContent = match.status === "FINISHED" ? "Aguardando apuração" : "Palpites encerrados"; footer.append(closed); }
    article.append(meta, teams, footer); return article;
  };

  const loadMatches = async (append = false) => {
    if (!append) { currentPage = 0; list?.replaceChildren(); }
    if (state) { state.hidden = false; state.textContent = "Carregando partidas…"; }
    try {
      const response = await authenticatedFetch(`/partidas/catalog?view=${currentView}&page=${currentPage}&size=12`);
      if (!response.ok) throw new Error("Não foi possível carregar as partidas.");
      const page = await response.json() as Page; total = page.total;
      page.items.forEach((match) => list?.append(renderMatch(match)));
      const count = list?.children.length || 0;
      if (state) { state.hidden = count > 0; state.textContent = "Nenhuma partida encontrada neste filtro."; }
      if (more) more.hidden = count >= total;
    } catch (error) { if (state) { state.hidden = false; state.textContent = error instanceof Error ? error.message : "Erro inesperado."; } }
  };

  document.querySelectorAll<HTMLButtonElement>("[data-view]").forEach((button) => button.addEventListener("click", () => {
    currentView = button.dataset.view || "OPEN";
    document.querySelectorAll<HTMLButtonElement>("[data-view]").forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
    void loadMatches();
  }));
  more?.addEventListener("click", () => { currentPage += 1; void loadMatches(true); });

  const showStep = (step: "form" | "review" | "result") => {
    if (form) form.hidden = step !== "form"; if (review) review.hidden = step !== "review"; if (result) result.hidden = step !== "result";
  };
  const openBet = (match: Match) => {
    selected = match; pending = undefined; form?.reset(); showStep("form");
    const heading = result?.querySelector("h3"); const copy = result?.querySelector("p"); const pulse = result?.querySelector<HTMLElement>(".bet-result__pulse");
    if (heading) heading.textContent = "Processando pagamento…"; if (copy) copy.textContent = "Aguarde enquanto confirmamos seu saldo."; if (pulse) pulse.hidden = false;
    document.querySelector<HTMLElement>("[data-bet-match]")!.textContent = `${match.teamHome} × ${match.teamAway}`;
    document.querySelector<HTMLElement>("[data-home-label]")!.textContent = match.teamHome;
    document.querySelector<HTMLElement>("[data-away-label]")!.textContent = match.teamAway;
    document.querySelector<HTMLElement>("[data-bet-kickoff]")!.textContent = `Início em ${dateTime.format(new Date(match.start))}`;
    document.querySelector<HTMLElement>("[data-bet-balance]")!.textContent = formatCents(balanceCents());
    document.querySelector<HTMLElement>("[data-bet-message]")!.textContent = ""; dialog?.showModal();
  };
  form?.addEventListener("submit", (event) => {
    event.preventDefault(); if (!selected || !form.reportValidity()) return;
    const data = new FormData(form); const home = Number(data.get("homeGoals")); const away = Number(data.get("awayGoals")); const stakeCents = parseCents(String(data.get("stake")));
    const message = document.querySelector<HTMLElement>("[data-bet-message]")!;
    if (!Number.isInteger(home) || !Number.isInteger(away) || home < 0 || away < 0 || home > 30 || away > 30) { message.textContent = "Informe um placar entre 0 e 30 gols."; return; }
    if (!Number.isSafeInteger(stakeCents) || stakeCents < 100) { message.textContent = "O valor mínimo é R$ 1,00."; return; }
    if (stakeCents > balanceCents()) { message.textContent = "Saldo insuficiente para este palpite."; return; }
    pending = { home, away, stakeCents, key: createIdempotencyKey() };
    document.querySelector<HTMLElement>("[data-review-match]")!.textContent = `${selected.teamHome} × ${selected.teamAway}`;
    document.querySelector<HTMLElement>("[data-review-score]")!.textContent = `${home} × ${away}`;
    document.querySelector<HTMLElement>("[data-review-stake]")!.textContent = formatCents(stakeCents);
    document.querySelector<HTMLElement>("[data-review-balance]")!.textContent = formatCents(balanceCents() - stakeCents); showStep("review");
  });
  document.querySelector("[data-bet-back]")?.addEventListener("click", () => { pending = undefined; showStep("form"); });

  const pollBet = async (id: string) => {
    const pendingStatuses = new Set<BetStatus>(["PROCESSING", "CANCELING", "REFUNDING"]);
    for (let attempt = 0; attempt < 15; attempt += 1) {
      await new Promise((resolve) => window.setTimeout(resolve, 1000));
      const response = await authenticatedFetch(`/bets/${id}`); if (!response.ok) continue;
      const bet = await response.json() as Bet;
      if (!pendingStatuses.has(bet.status)) return bet;
    }
    return undefined;
  };
  document.querySelector("[data-bet-confirm]")?.addEventListener("click", async () => {
    if (!selected || !pending) return; const button = document.querySelector<HTMLButtonElement>("[data-bet-confirm]")!; button.disabled = true;
    document.querySelector<HTMLElement>("[data-review-message]")!.textContent = "";
    try {
      const response = await authenticatedFetch("/bets", { method: "POST", headers: { "Content-Type": "application/json", "Idempotency-Key": pending.key }, body: JSON.stringify({ match_id: selected.id, home_team_goals: pending.home, away_team_goals: pending.away, stake_amount: (pending.stakeCents / 100).toFixed(2) }) });
      const created = await response.json().catch(() => ({})) as Bet & { detail?: string; message?: string };
      if (!response.ok) throw new Error(created.detail || created.message || "Não foi possível enviar o palpite.");
      showStep("result"); const terminal = created.status === "PROCESSING" ? await pollBet(created.bet_id) : created;
      const heading = result?.querySelector("h3"); const copy = result?.querySelector("p"); const pulse = result?.querySelector<HTMLElement>(".bet-result__pulse");
      if (terminal?.status === "CONFIRMED" || terminal?.status === "AWAITING_SETTLEMENT") { if (heading) heading.textContent = "Palpite confirmado"; if (copy) copy.textContent = "O valor foi reservado na sua carteira."; if (pulse) pulse.hidden = true; await refreshWallet(); }
      else if (terminal?.status === "PAYMENT_REFUSED") { if (heading) heading.textContent = "Pagamento recusado"; if (copy) copy.textContent = "Seu saldo não foi alterado."; if (pulse) pulse.hidden = true; await refreshWallet(); }
      else if (terminal?.status === "CANCELED") { if (heading) heading.textContent = "Palpite cancelado"; if (copy) copy.textContent = "A movimentação financeira foi encerrada."; if (pulse) pulse.hidden = true; await refreshWallet(); }
      else if (terminal?.status === "REFUND_FAILED") { if (heading) heading.textContent = "Falha no estorno"; if (copy) copy.textContent = "A equipe poderá reprocessar a devolução do valor."; if (pulse) pulse.hidden = true; await refreshWallet(); }
      else { if (heading) heading.textContent = "Palpite em processamento"; if (copy) copy.textContent = "Você pode acompanhar a confirmação em Meus palpites."; }
    } catch (error) { document.querySelector<HTMLElement>("[data-review-message]")!.textContent = error instanceof Error ? error.message : "Erro inesperado."; }
    finally { button.disabled = false; }
  });
  const closeDialog = () => dialog?.close(); document.querySelector("[data-bet-close]")?.addEventListener("click", closeDialog); document.querySelector("[data-bet-done]")?.addEventListener("click", closeDialog);

  const start = () => void loadMatches();
  if (document.querySelector("[data-user-shell]:not([hidden])")) start(); else window.addEventListener("user:ready", start, { once: true });
</script>

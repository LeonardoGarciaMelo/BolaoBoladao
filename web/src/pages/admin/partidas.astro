---
import Layout from "../../layouts/Layout.astro";
import AdminShell from "../../components/templates/AdminShell.astro";
---
<Layout title="Partidas | Admin Bolão Boladão">
  <AdminShell active="matches" eyebrow="GESTÃO ESPORTIVA" title="Partidas">
    <div class="admin-split">
      <section class="admin-card admin-create-match">
        <header class="admin-card__header"><div><p>NOVA DISPUTA</p><h2>Criar partida</h2></div></header>
        <form data-match-form class="admin-form">
          <label>MANDANTE<input name="teamHomeName" list="team-options" required minlength="2" autocomplete="off" /></label>
          <label>VISITANTE<input name="teamAwayName" list="team-options" required minlength="2" autocomplete="off" /></label>
          <datalist id="team-options"></datalist>
          <div class="admin-datetime-fields">
            <label>DATA<input name="startDate" type="date" aria-required="true" /></label>
            <label>HORÁRIO<input name="startTime" type="time" step="60" aria-required="true" /></label>
            <label>DURAÇÃO (MIN)<input name="durationMinutes" type="number" min="1" max="300" value="105" required /></label>
          </div>
          <p class="admin-form__hint" data-timezone></p>
          <p class="admin-form__hint" data-end-preview>Informe data, horário e duração para ver o término previsto.</p>
          <p class="admin-form__message" data-match-message role="alert"></p>
          <button class="admin-action" type="submit">CRIAR PARTIDA</button>
        </form>
      </section>
      <section class="admin-card admin-match-list-card">
        <header class="admin-card__header"><div><p>AGENDA</p><h2>Partidas cadastradas</h2></div><select data-status-filter aria-label="Filtrar por status"><option value="">TODAS</option><option value="SCHEDULED">AGENDADAS</option><option value="IN_PROGRESS">AO VIVO</option><option value="FINISHED">ENCERRADAS</option><option value="CANCELED">CANCELADAS</option></select></header>
        <div class="admin-match-list" data-match-list><p class="admin-empty">Carregando partidas…</p></div>
      </section>
    </div>
    <dialog class="admin-dialog" data-cancel-dialog>
      <form method="dialog" data-cancel-form>
        <span class="admin-dialog__eyebrow">AÇÃO IRREVERSÍVEL</span><h2>Cancelar partida?</h2>
        <p data-cancel-match-label></p>
        <label>MOTIVO DO CANCELAMENTO<textarea name="reason" minlength="10" maxlength="500" required></textarea></label>
        <p class="admin-form__message" data-cancel-message role="alert"></p>
        <div><button value="close" class="admin-secondary">VOLTAR</button><button value="confirm" class="admin-danger">CANCELAR PARTIDA</button></div>
      </form>
    </dialog>
    <dialog class="admin-dialog" data-command-dialog>
      <form method="dialog" data-command-form>
        <span class="admin-dialog__eyebrow">CONFIRMAR AÇÃO</span><h2 data-command-title>Confirmar?</h2>
        <p data-command-copy></p>
        <p class="admin-form__message" data-command-message role="alert"></p>
        <div><button value="close" class="admin-secondary">VOLTAR</button><button value="confirm" class="admin-action">CONFIRMAR</button></div>
      </form>
    </dialog>
  </AdminShell>
</Layout>

<script>
  import { authenticatedFetch, createIdempotencyKey, requireAdmin } from "../../scripts/session";
  import { matchStatusLabel, readApiError, refundStatusLabel } from "../../scripts/presentation";
  type Match = { id: string; teamHome: string; teamAway: string; teamHomeScore: number; teamAwayScore: number; start: string; durationMinutes: number; expectedEnd: string; startedAt?: string; end?: string; status: string; cancelReason?: string };
  const list = document.querySelector<HTMLElement>("[data-match-list]");
  const form = document.querySelector<HTMLFormElement>("[data-match-form]");
  const message = document.querySelector<HTMLElement>("[data-match-message]");
  const filter = document.querySelector<HTMLSelectElement>("[data-status-filter]");
  const dialog = document.querySelector<HTMLDialogElement>("[data-cancel-dialog]");
  const cancelForm = document.querySelector<HTMLFormElement>("[data-cancel-form]");
  const commandDialog = document.querySelector<HTMLDialogElement>("[data-command-dialog]");
  const commandForm = document.querySelector<HTMLFormElement>("[data-command-form]");
  let selectedMatch: Match | undefined;
  let selectedCommand: { action: "iniciar" | "encerrar" | "anular"; side?: "HOME" | "AWAY" } | undefined;
  let loadingMatches = false;
  let createKey: string | undefined;
  let cancelKey: string | undefined;
  const retryKeys = new Map<string, string>();
  const formatter = new Intl.DateTimeFormat("pt-BR", { dateStyle: "short", timeStyle: "short" });
  document.querySelector<HTMLElement>("[data-timezone]")!.textContent = `Fuso exibido: ${Intl.DateTimeFormat().resolvedOptions().timeZone}`;

  const loadTeams = async (query: string) => {
    const response = await authenticatedFetch(`/admin/teams?q=${encodeURIComponent(query)}&limit=12`);
    if (!response.ok) return;
    const options = document.querySelector<HTMLDataListElement>("#team-options");
    options?.replaceChildren(...(await response.json()).map((team: { name: string }) => {
      const option = document.createElement("option"); option.value = team.name; return option;
    }));
  };

  const loadMatches = async () => {
    if (loadingMatches) return;
    loadingMatches = true;
    try {
    await requireAdmin();
    const status = filter?.value ? `&status=${filter.value}` : "";
    const response = await authenticatedFetch(`/admin/partidas?page=0&size=50${status}`);
    if (!response.ok) throw new Error(await readApiError(response, "Não foi possível carregar as partidas."));
    const page = await response.json();
    if (!list) return;
    list.replaceChildren();
    if (!page.items?.length) { const empty = document.createElement("p"); empty.className = "admin-empty"; empty.textContent = "Nenhuma partida nesta seleção."; list.append(empty); return; }
    for (const match of page.items as Match[]) list.append(renderMatch(match));
    } catch (error) {
      if (list) list.innerHTML = `<p class="admin-empty">${error instanceof Error ? error.message : "Não foi possível carregar as partidas."}</p>`;
    } finally { loadingMatches = false; }
  };

  const renderMatch = (match: Match) => {
    const row = document.createElement("article"); row.className = "admin-match-row";
    const status = document.createElement("span"); status.className = `admin-status admin-status--${match.status.toLowerCase()}`; status.textContent = matchStatusLabel(match.status);
    const copy = document.createElement("div");
    const teams = document.createElement("strong"); teams.textContent = `${match.teamHome} × ${match.teamAway}`;
    const date = document.createElement("time"); date.textContent = `Início previsto: ${formatter.format(new Date(match.start))}`;
    const expected = document.createElement("time"); expected.textContent = match.status === "FINISHED" && match.end
      ? `Encerrada em: ${formatter.format(new Date(match.end))}`
      : `Término previsto: ${formatter.format(new Date(match.expectedEnd))}`;
    copy.append(teams, date, expected);
    if (match.status !== "SCHEDULED") { const score = document.createElement("b"); score.className = "admin-live-score"; score.textContent = `${match.teamHomeScore} × ${match.teamAwayScore}`; copy.append(score); }
    row.append(status, copy);
    const actions = document.createElement("div"); actions.className = "admin-match-actions";
    if (match.status === "SCHEDULED") actions.append(actionButton("INICIAR AGORA", () => confirmCommand(match, "iniciar")));
    if (match.status === "IN_PROGRESS") {
      actions.append(scoreControl(match, "HOME"), scoreControl(match, "AWAY"));
      actions.append(actionButton("ENCERRAR AGORA", () => confirmCommand(match, "encerrar")));
    }
    if (["SCHEDULED", "IN_PROGRESS"].includes(match.status)) {
      const button = document.createElement("button"); button.className = "admin-cancel-trigger"; button.textContent = "CANCELAR";
      button.addEventListener("click", () => { selectedMatch = match; cancelKey = undefined; document.querySelector<HTMLElement>("[data-cancel-match-label]")!.textContent = `${match.teamHome} × ${match.teamAway}`; dialog?.showModal(); });
      actions.append(button); row.append(actions);
    } else if (match.status === "CANCELED") {
      const audit = document.createElement("div"); audit.className = "admin-match-refund";
      const reason = document.createElement("small"); reason.textContent = match.cancelReason || "Cancelada";
      const progress = document.createElement("span"); progress.textContent = "ESTORNOS: CONSULTANDO";
      const retry = document.createElement("button"); retry.className = "admin-cancel-trigger"; retry.textContent = "REPROCESSAR ESTORNOS"; retry.hidden = true;
      retry.addEventListener("click", async () => {
        retry.disabled = true;
        const response = await authenticatedFetch(`/admin/partidas/${match.id}/refunds/retry`, { method: "POST" });
        retry.disabled = false;
        if (response.ok) { retry.hidden = true; progress.textContent = "ESTORNOS: REPROCESSANDO"; void pollRefunds(match.id, progress, retry); }
      });
      audit.append(reason, progress, retry); row.append(audit); void pollRefunds(match.id, progress, retry);
    }
    return row;
  };

  const actionButton = (label: string, handler: () => void) => {
    const button = document.createElement("button"); button.type = "button"; button.className = "admin-secondary admin-match-action"; button.textContent = label; button.addEventListener("click", handler); return button;
  };
  const scoreControl = (match: Match, side: "HOME" | "AWAY") => {
    const control = document.createElement("div"); control.className = "admin-score-control";
    const label = document.createElement("span"); label.textContent = side === "HOME" ? match.teamHome : match.teamAway;
    const minus = actionButton("−", () => confirmCommand(match, "anular", side)); minus.ariaLabel = `Anular gol de ${label.textContent}`; minus.disabled = (side === "HOME" ? match.teamHomeScore : match.teamAwayScore) <= 0;
    const value = document.createElement("b"); value.textContent = String(side === "HOME" ? match.teamHomeScore : match.teamAwayScore);
    const plus = actionButton("+", () => void sendCommand(match, "gol", side).catch((error) => {
      const knownMessage = error instanceof Error && !/fetch|network|load failed/i.test(error.message) ? error.message : undefined;
      if (message) message.textContent = knownMessage || "Não foi possível adicionar o gol.";
    })); plus.ariaLabel = `Adicionar gol de ${label.textContent}`; plus.disabled = Number(value.textContent) >= 99;
    control.append(label, minus, value, plus); return control;
  };
  const confirmCommand = (match: Match, action: "iniciar" | "encerrar" | "anular", side?: "HOME" | "AWAY") => {
    selectedMatch = match; selectedCommand = { action, side };
    const team = side === "HOME" ? match.teamHome : match.teamAway;
    document.querySelector<HTMLElement>("[data-command-title]")!.textContent = action === "iniciar" ? "Iniciar partida agora?" : action === "encerrar" ? "Encerrar partida agora?" : "Anular este gol?";
    document.querySelector<HTMLElement>("[data-command-copy]")!.textContent = action === "anular" ? `O placar de ${team} será reduzido em um gol.` : `${match.teamHome} × ${match.teamAway}`;
    document.querySelector<HTMLElement>("[data-command-message]")!.textContent = ""; commandDialog?.showModal();
  };
  const sendCommand = async (match: Match, action: "iniciar" | "gol" | "anular" | "encerrar", side?: "HOME" | "AWAY") => {
    if (message) message.textContent = "";
    const commandId = `${match.id}:${action}:${side || ""}`;
    const key = retryKeys.get(commandId) || createIdempotencyKey(); retryKeys.set(commandId, key);
    const path = action === "anular" ? "gol/anular" : action;
    const options: RequestInit = { method: "POST", headers: { "Idempotency-Key": key } };
    if (side) { options.headers = { ...options.headers, "Content-Type": "application/json" }; options.body = JSON.stringify({ side }); }
    const controls = Array.from(document.querySelectorAll<HTMLButtonElement>(".admin-match-actions button")); controls.forEach((item) => item.disabled = true);
    try {
      const response = await authenticatedFetch(`/admin/partidas/${match.id}/${path}`, options);
      if (!response.ok) throw new Error(await readApiError(response, "Não foi possível atualizar a partida."));
      retryKeys.delete(commandId); await loadMatches();
    } finally { controls.forEach((item) => item.disabled = false); }
  };

  const pollRefunds = async (matchId: string, target: HTMLElement, retry?: HTMLButtonElement) => {
    for (let attempt = 0; attempt < 10; attempt += 1) {
      const response = await authenticatedFetch(`/admin/partidas/${matchId}/refunds`);
      if (response.ok) {
        const progress = await response.json();
        target.textContent = `ESTORNOS: ${refundStatusLabel(progress.status)} · ${progress.completed}/${progress.total}`;
        target.dataset.status = String(progress.status).toLowerCase();
        if (progress.status === "FAILED") { if (retry) retry.hidden = false; return; }
        if (progress.status === "COMPLETED") return;
      } else if (response.status !== 404) return;
      await new Promise((resolve) => window.setTimeout(resolve, 1000));
    }
    target.textContent = "ESTORNOS: PROCESSANDO";
  };

  form?.querySelectorAll<HTMLInputElement>("input[list]").forEach((input) => input.addEventListener("input", () => {
    if (input.value.trim().length >= 2) void loadTeams(input.value.trim());
  }));
  form?.addEventListener("submit", async (event) => {
    event.preventDefault(); if (!message) return;
    const data = new FormData(form);
    const startDate = String(data.get("startDate") || "");
    const startTime = String(data.get("startTime") || "");
    if (!startDate || !startTime) { message.textContent = "Informe a data e o horário da partida."; return; }
    if (!form.reportValidity()) return;
    const localStart = new Date(`${startDate}T${startTime}:00`);
    const durationMinutes = Number(data.get("durationMinutes"));
    if (Number.isNaN(localStart.valueOf()) || localStart <= new Date()) { message.textContent = "Escolha um horário futuro válido."; return; }
    if (!Number.isInteger(durationMinutes) || durationMinutes < 1 || durationMinutes > 300) { message.textContent = "A duração deve ficar entre 1 e 300 minutos."; return; }
    if (!createKey) createKey = createIdempotencyKey();
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]')!; submit.disabled = true;
    try {
      const response = await authenticatedFetch("/admin/partidas", { method: "POST", headers: { "Content-Type": "application/json", "Idempotency-Key": createKey }, body: JSON.stringify({ teamHomeName: data.get("teamHomeName"), teamAwayName: data.get("teamAwayName"), start: localStart.toISOString(), durationMinutes }) });
      message.textContent = response.ok ? "Partida criada e adicionada à agenda." : await readApiError(response, "Não foi possível criar a partida.");
      if (response.ok) { createKey = undefined; form.reset(); (form.elements.namedItem("durationMinutes") as HTMLInputElement).value = "105"; updateEndPreview(); await loadMatches(); }
    } catch {
      message.textContent = "Não foi possível criar a partida. Tente novamente.";
    } finally { submit.disabled = false; }
  });
  form?.addEventListener("input", () => { createKey = undefined; });
  const updateEndPreview = () => {
    const data = new FormData(form!); const date = String(data.get("startDate") || ""); const time = String(data.get("startTime") || ""); const duration = Number(data.get("durationMinutes"));
    const preview = document.querySelector<HTMLElement>("[data-end-preview]")!;
    if (!date || !time || !Number.isFinite(duration)) { preview.textContent = "Informe data, horário e duração para ver o término previsto."; return; }
    const end = new Date(new Date(`${date}T${time}:00`).getTime() + duration * 60_000); preview.textContent = `Término previsto: ${formatter.format(end)}`;
  };
  form?.querySelectorAll('input[name="startDate"],input[name="startTime"],input[name="durationMinutes"]').forEach((input) => input.addEventListener("input", updateEndPreview));
  commandForm?.addEventListener("submit", async (event) => {
    const submitter = (event as SubmitEvent).submitter as HTMLButtonElement | null; if (submitter?.value !== "confirm") return;
    event.preventDefault(); if (!selectedMatch || !selectedCommand) return; submitter.disabled = true;
    try { await sendCommand(selectedMatch, selectedCommand.action, selectedCommand.side); commandDialog?.close(); selectedCommand = undefined; }
    catch (error) { document.querySelector<HTMLElement>("[data-command-message]")!.textContent = error instanceof Error ? error.message : "Não foi possível atualizar a partida."; }
    finally { submitter.disabled = false; }
  });
  cancelForm?.addEventListener("submit", async (event) => {
    const submitter = (event as SubmitEvent).submitter as HTMLButtonElement | null;
    if (submitter?.value !== "confirm") return;
    event.preventDefault(); if (!selectedMatch || !cancelForm.reportValidity()) return;
    const reason = String(new FormData(cancelForm).get("reason"));
    if (!cancelKey) cancelKey = createIdempotencyKey(); submitter.disabled = true;
    const cancelMessage = document.querySelector<HTMLElement>("[data-cancel-message]");
    try {
      const response = await authenticatedFetch(`/admin/partidas/${selectedMatch.id}/cancel`, { method: "POST", headers: { "Content-Type": "application/json", "Idempotency-Key": cancelKey }, body: JSON.stringify({ reason }) });
      if (!response.ok) { if (cancelMessage) cancelMessage.textContent = await readApiError(response, "Não foi possível cancelar."); return; }
      cancelKey = undefined; dialog?.close(); cancelForm.reset(); selectedMatch = undefined; await loadMatches();
    } catch {
      if (cancelMessage) cancelMessage.textContent = "Não foi possível cancelar a partida. Tente novamente.";
    } finally { submitter.disabled = false; }
  });
  cancelForm?.querySelector("textarea")?.addEventListener("input", () => { cancelKey = undefined; });
  filter?.addEventListener("change", () => void loadMatches());
  window.setInterval(() => { if (document.visibilityState === "visible") void loadMatches(); }, 5000);
  if (document.querySelector("[data-admin-shell]:not([hidden])")) void loadMatches();
  else window.addEventListener("admin:ready", () => void loadMatches(), { once: true });
</script>
